# Binance API Credentials
# Replace with your actual Binance API Key and Secret in your private .env file
API_KEY=your_binance_api_key_here
SECRET_KEY=your_binance_secret_key_here

# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Binance Base URLs (Default standard API)
BINANCE_BASE_URL=https://api.binance.com
BINANCE_DATA_URL=https://data-api.binance.vision
